<?xml version='1.0' encoding='UTF-8'?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd"><changeSet author="modernization" id="api_key_trigger_pg" dbms="postgresql">
        <sql splitStatements="false">
            CREATE OR REPLACE FUNCTION generate_api_key() RETURNS TRIGGER AS $$
            BEGIN
                IF NEW.api_key IS NULL THEN
                    NEW.api_key := replace(CAST(gen_random_uuid() AS text), '-', '');
                    NEW.enable_api_key := true;
                END IF;
                RETURN NEW;
            END;
            $$ LANGUAGE plpgsql;

            DROP TRIGGER IF EXISTS user_account_api_key_trg ON user_account;
            CREATE TRIGGER user_account_api_key_trg
            BEFORE INSERT ON user_account
            FOR EACH ROW EXECUTE PROCEDURE generate_api_key();
        </sql>
        <rollback>-- Automated rollback: Data/schema changes must be manually reviewed if destructive.</rollback>
    </changeSet>
    
    <changeSet author="modernization" id="api_key_trigger_oracle" dbms="oracle">
        <sql splitStatements="false">
            CREATE OR REPLACE TRIGGER user_account_api_key_trg
            BEFORE INSERT ON user_account
            FOR EACH ROW
            BEGIN
                IF :NEW.api_key IS NULL THEN
                    :NEW.api_key := lower(rawtohex(sys_guid()));
                    :NEW.enable_api_key := 1;
                END IF;
            END;
        </sql>
        <rollback>-- Automated rollback: Data/schema changes must be manually reviewed if destructive.</rollback>
    </changeSet>

