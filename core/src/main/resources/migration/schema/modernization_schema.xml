        <addForeignKeyConstraint baseColumnNames="discrepancy_note_id" baseTableName="audit_event_discrepancy_note" constraintName="fk_aedn_disc_note" referencedColumnNames="discrepancy_note_id" referencedTableName="discrepancy_note" />
