# OpenClinica Environment Variables
# Copy this file to .env and adjust as necessary

# Database Configuration
# Database type (e.g., postgres)
DB_TYPE=postgres
# Database host
DB_HOST=localhost
# Database port
DB_PORT=5432
# Database user
DB_USER=clinica
# Database password
DB_PASS=clinica
# Database name
DB=clinica

# Application Configuration
# Web address for the system
SYS_URL=
# Directory for logs
LOG_DIR=
# Directory for uploaded and generated files inside container
FILE_PATH=/opt/clinica/data/
# Host directory mapped to FILE_PATH
HOST_FILE_PATH=./data

# LDAP Configuration
# Enable/disable LDAP authentication
LDAP_ENABLED=false
# LDAP server host
LDAP_HOST=ldap://localhost:389
# LDAP user DN
LDAP_USER_DN=cn=admin,dc=localhost
# LDAP password
LDAP_PASSWORD=localhost

# Seed Clinical Data Configuration
# Enable clinical data seeding?
SEED_CLINICAL_DATA=false
# Path to local Excel template mapped to CLINICAL_TEMPLATE_PATH
HOST_CLINICAL_TEMPLATE_PATH=./dummy_template.xlsx
# Path inside container
CLINICAL_TEMPLATE_PATH=
